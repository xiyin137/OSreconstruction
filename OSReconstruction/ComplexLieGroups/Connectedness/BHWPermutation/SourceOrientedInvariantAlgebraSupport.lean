import OSReconstruction.ComplexLieGroups.Connectedness.BHWPermutation.SourceOrientedAlgebraicRelations
import Mathlib.Algebra.MvPolynomial.Basic

/-!
# Generic algebra support for oriented invariant-ring transport

This file contains small algebra lemmas needed by the oriented invariant-ring
normality route.  They are independent of the special orthogonal invariant
theory itself: polynomial algebra maps have range generated by images of
variables, and surjectivity/equality transport along algebra equivalences is
formal.
-/

noncomputable section

set_option linter.unnecessarySimpa false

open Complex Topology Matrix LorentzLieGroup Classical Filter NormedSpace

namespace BHW

/-- The range of an algebra map out of a multivariable polynomial algebra is
contained in the algebra generated by the images of the variables. -/
theorem algHom_range_le_adjoin_images_mvPolynomial_X
    {σ A : Type*}
    [CommSemiring A] [Algebra ℂ A]
    (f : MvPolynomial σ ℂ →ₐ[ℂ] A) :
    f.range ≤
      Algebra.adjoin ℂ (Set.range (fun i : σ => f (MvPolynomial.X i))) := by
  intro y hy
  rcases hy with ⟨p, rfl⟩
  induction p using MvPolynomial.induction_on with
  | C a =>
      simpa using
        Algebra.algebraMap_mem
          (Algebra.adjoin ℂ
            (Set.range (fun i : σ => f (MvPolynomial.X i)))) a
  | add p q hp hq =>
      simpa using
        (Algebra.adjoin ℂ
          (Set.range
            (fun i : σ => f (MvPolynomial.X i)))).add_mem hp hq
  | mul_X p i hp =>
      have hX :
          f (MvPolynomial.X i) ∈
            Algebra.adjoin ℂ
              (Set.range
                (fun i : σ => f (MvPolynomial.X i))) :=
        Algebra.subset_adjoin ⟨i, rfl⟩
      simpa [map_mul] using
        (Algebra.adjoin ℂ
          (Set.range
            (fun i : σ => f (MvPolynomial.X i)))).mul_mem hp hX

/-- Map a subalgebra across an algebra equivalence. -/
def algEquivMapSubalgebra
    {A B : Type*} [CommSemiring A] [CommSemiring B]
    [Algebra ℂ A] [Algebra ℂ B]
    (e : A ≃ₐ[ℂ] B)
    (S : Subalgebra ℂ A) : Subalgebra ℂ B :=
  S.map e.toAlgHom

/-- Map an ideal across an algebra equivalence. -/
def algEquivMapIdeal
    {A B : Type*} [CommSemiring A] [CommSemiring B]
    [Algebra ℂ A] [Algebra ℂ B]
    (e : A ≃ₐ[ℂ] B)
    (I : Ideal A) : Ideal B :=
  I.map e.toRingHom

/-- If an algebra equivalence maps one subalgebra onto another, then it
restricts to an algebra equivalence between the subalgebras. -/
def algEquivOfMappedSubalgebraEq
    {A B : Type*} [CommSemiring A] [CommSemiring B]
    [Algebra ℂ A] [Algebra ℂ B]
    (e : A ≃ₐ[ℂ] B)
    (S : Subalgebra ℂ A)
    (T : Subalgebra ℂ B)
    (hST : algEquivMapSubalgebra e S = T) :
    S ≃ₐ[ℂ] T :=
  { toFun := fun x =>
      ⟨e x, by
        simpa [← hST, algEquivMapSubalgebra] using
          Subalgebra.mem_map.mpr ⟨x, x.2, rfl⟩⟩
    invFun := fun y =>
      ⟨e.symm y, by
        have hy_map :
            (y : B) ∈ algEquivMapSubalgebra e S := by
          simpa [hST] using y.2
        rcases Subalgebra.mem_map.mp hy_map with
          ⟨x, hxS, hx⟩
        have : e.symm y = x := by
          apply e.injective
          simpa using hx.symm
        simpa [this] using hxS⟩
    left_inv := by intro x; ext; simp
    right_inv := by intro y; ext; simp
    map_mul' := by intro x y; ext; simp
    map_add' := by intro x y; ext; simp
    commutes' := by intro r; ext; simp }

/-- Mapping subalgebras across an algebra equivalence is injective. -/
theorem algEquivMapSubalgebra_injective
    {A B : Type*} [CommSemiring A] [CommSemiring B]
    [Algebra ℂ A] [Algebra ℂ B]
    (e : A ≃ₐ[ℂ] B) :
    Function.Injective (algEquivMapSubalgebra e) := by
  intro S T hST
  have hmap :
      Subalgebra.map e.symm.toAlgHom (algEquivMapSubalgebra e S) =
        Subalgebra.map e.symm.toAlgHom (algEquivMapSubalgebra e T) := by
    simpa using
      congrArg
        (fun U : Subalgebra ℂ B => Subalgebra.map e.symm.toAlgHom U)
        hST
  unfold algEquivMapSubalgebra at hmap
  rw [Subalgebra.map_map] at hmap
  rw [Subalgebra.map_map] at hmap
  have hcomp : e.symm.toAlgHom.comp e.toAlgHom = AlgHom.id ℂ A := by
    ext x
    exact e.symm_apply_apply x
  rw [hcomp] at hmap
  simpa using hmap

/-- Mapping ideals across an algebra equivalence is injective. -/
theorem algEquivMapIdeal_injective
    {A B : Type*} [CommSemiring A] [CommSemiring B]
    [Algebra ℂ A] [Algebra ℂ B]
    (e : A ≃ₐ[ℂ] B) :
    Function.Injective (algEquivMapIdeal e) := by
  intro I J hIJ
  have hmap :
      Ideal.map e.symm.toRingHom (algEquivMapIdeal e I) =
        Ideal.map e.symm.toRingHom (algEquivMapIdeal e J) := by
    simpa using
      congrArg (fun K : Ideal B => Ideal.map e.symm.toRingHom K) hIJ
  unfold algEquivMapIdeal at hmap
  rw [Ideal.map_map] at hmap
  rw [Ideal.map_map] at hmap
  have hcomp : e.symm.toRingHom.comp e.toRingHom = RingHom.id A := by
    ext x
    exact e.symm_apply_apply x
  rw [hcomp] at hmap
  simpa using hmap

/-- The kernel of a commuting algebra-map square transports across algebra
equivalences. -/
theorem algEquivMapIdeal_ker_of_commutes
    {A B C D : Type*}
    [CommSemiring A] [CommSemiring B]
    [CommSemiring C] [CommSemiring D]
    [Algebra ℂ A] [Algebra ℂ B]
    [Algebra ℂ C] [Algebra ℂ D]
    (eDomain : A ≃ₐ[ℂ] B)
    (eCodomain : C ≃ₐ[ℂ] D)
    (f : A →ₐ[ℂ] C)
    (g : B →ₐ[ℂ] D)
    (hmap : ∀ x, eCodomain (f x) = g (eDomain x)) :
    algEquivMapIdeal eDomain (RingHom.ker f) = RingHom.ker g := by
  ext y
  constructor
  · intro hy
    unfold algEquivMapIdeal at hy
    rw [Ideal.mem_map_iff_of_surjective] at hy
    · rcases hy with ⟨x, hx, rfl⟩
      change g (eDomain x) = 0
      rw [← hmap x]
      rw [show f x = 0 from hx]
      simp
    · exact eDomain.toRingEquiv.surjective
  · intro hy
    unfold algEquivMapIdeal
    rw [Ideal.mem_map_iff_of_surjective]
    · refine ⟨eDomain.symm y, ?_, by simp⟩
      change f (eDomain.symm y) = 0
      apply eCodomain.injective
      rw [hmap]
      simpa using hy
    · exact eDomain.toRingEquiv.surjective

/-- Transport surjectivity through algebra equivalences on source and target. -/
theorem surjective_of_algEquiv_transport
    {A B C D : Type*}
    [CommSemiring A] [CommSemiring B]
    [CommSemiring C] [CommSemiring D]
    [Algebra ℂ A] [Algebra ℂ B]
    [Algebra ℂ C] [Algebra ℂ D]
    (eDomain : A ≃ₐ[ℂ] B)
    (eCodomain : C ≃ₐ[ℂ] D)
    (f : A →ₐ[ℂ] C)
    (g : B →ₐ[ℂ] D)
    (hmap : ∀ x, eCodomain (f x) = g (eDomain x))
    (hg : Function.Surjective g) :
    Function.Surjective f := by
  intro y
  rcases hg (eCodomain y) with ⟨x, hx⟩
  refine ⟨eDomain.symm x, ?_⟩
  apply eCodomain.injective
  simpa [hmap] using hx

end BHW
