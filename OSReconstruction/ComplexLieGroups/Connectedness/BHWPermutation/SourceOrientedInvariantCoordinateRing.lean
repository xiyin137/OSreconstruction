import OSReconstruction.ComplexLieGroups.Connectedness.BHWPermutation.SourceOrientedInvariantAlgebraSupport

/-!
# Coordinate rings for the oriented invariant-theory packet

This file fixes the polynomial coordinate rings and explicit relation ideals
used by the oriented normality route.  It does not assert the first or second
fundamental theorem for `SO`; it only names the standard-dot and source-side
generators/relations that those theorems must use.
-/

noncomputable section

open Complex Topology Matrix LorentzLieGroup Classical Filter NormedSpace

namespace BHW

/-- Polynomial coordinate ring for `n` vectors in the standard dot model
`ℂ^D`. -/
abbrev standardTupleCoordinateRing
    (D n : ℕ) :=
  MvPolynomial (Fin n × Fin D) ℂ

/-- Pairing coordinate polynomial in the standard dot model. -/
def standardPairingCoordinatePolynomial
    (D n : ℕ)
    (ij : Fin n × Fin n) :
    standardTupleCoordinateRing D n :=
  ∑ μ : Fin D,
    MvPolynomial.X (ij.1, μ) * MvPolynomial.X (ij.2, μ)

/-- Ordered volume coordinate polynomial in the standard dot model. -/
def standardVolumeCoordinatePolynomial
    (D n : ℕ)
    (ι : Fin D ↪ Fin n) :
    standardTupleCoordinateRing D n :=
  Matrix.det (fun a μ : Fin D => MvPolynomial.X (ι a, μ))

/-- Polynomial coordinate ring for `n` source vectors in complex Minkowski
coordinates. -/
abbrev sourceTupleCoordinateRing
    (d n : ℕ) :=
  MvPolynomial (Fin n × Fin (d + 1)) ℂ

/-- Source Minkowski Gram coordinate polynomial. -/
def sourceGramCoordinatePolynomial
    (d n : ℕ)
    (ij : Fin n × Fin n) :
    sourceTupleCoordinateRing d n :=
  ∑ μ : Fin (d + 1),
    MvPolynomial.C (MinkowskiSpace.metricSignature d μ : ℂ) *
      MvPolynomial.X (ij.1, μ) * MvPolynomial.X (ij.2, μ)

/-- Selected source full-frame determinant coordinate polynomial. -/
def sourceFullFrameDetPolynomial
    (d n : ℕ)
    (ι : Fin (d + 1) ↪ Fin n) :
    sourceTupleCoordinateRing d n :=
  Matrix.det (fun a μ : Fin (d + 1) => MvPolynomial.X (ι a, μ))

/-- Polynomial coordinate ring whose variables represent standard pairings
and ordered volumes. -/
abbrev standardSOInvariantCoordinateRing
    (D n : ℕ) :=
  MvPolynomial ((Fin n × Fin n) ⊕ (Fin D ↪ Fin n)) ℂ

/-- Linear vector-bracket syzygy in the standard-dot SO presentation. -/
def standardSOLinearSyzygyRelation
    (D n : ℕ)
    (i : Fin n)
    (ι : Fin (D + 1) ↪ Fin n) :
    standardSOInvariantCoordinateRing D n :=
  ∑ k : Fin (D + 1),
    MvPolynomial.C ((-1 : ℂ) ^ (k : ℕ)) *
      MvPolynomial.X (Sum.inl (i, ι k)) *
        MvPolynomial.X (Sum.inr (finDeleteEmbedding k ι))

/-- Explicit standard-dot relation generators for the special orthogonal
pairing/volume coordinate presentation. -/
def standardSOAlgebraicRelationGenerators
    (D n : ℕ) :
    Set (standardSOInvariantCoordinateRing D n) :=
  ((Set.range
      (fun ij : Fin n × Fin n =>
        MvPolynomial.X (Sum.inl ij) -
          MvPolynomial.X (Sum.inl (ij.2, ij.1)))) ∪
    (Set.range
      (fun ι : Fin (D + 1) ↪ Fin n =>
        Matrix.det
          (fun a b : Fin (D + 1) =>
            MvPolynomial.X (Sum.inl (ι a, ι b))))) ∪
    (Set.range
      (fun p : (Fin D ↪ Fin n) × Equiv.Perm (Fin D) =>
        MvPolynomial.X (Sum.inr (p.2.toEmbedding.trans p.1)) -
          MvPolynomial.C (p.2.sign : ℂ) *
            (MvPolynomial.X (Sum.inr p.1) :
              standardSOInvariantCoordinateRing D n))) ∪
    (Set.range
      (fun p : (Fin D ↪ Fin n) × (Fin D ↪ Fin n) =>
        Matrix.det
            (fun a b : Fin D =>
              MvPolynomial.X (Sum.inl (p.1 a, p.2 b))) -
          MvPolynomial.X (Sum.inr p.1) *
            MvPolynomial.X (Sum.inr p.2)))) ∪
  (Set.range
    (fun p : Fin n × (Fin (D + 1) ↪ Fin n) =>
      standardSOLinearSyzygyRelation D n p.1 p.2))

/-- The ideal generated by the explicit standard-dot `SO` relations. -/
def standardSOAlgebraicRelationIdeal
    (D n : ℕ) :
    Ideal (standardSOInvariantCoordinateRing D n) :=
  Ideal.span (standardSOAlgebraicRelationGenerators D n)

/-- Source-side invariant coordinate ring: variables for source Gram
coordinates and ordered full-frame determinant coordinates. -/
abbrev sourceOrientedInvariantCoordinateRing
    (d n : ℕ) :=
  MvPolynomial ((Fin n × Fin n) ⊕ (Fin (d + 1) ↪ Fin n)) ℂ

/-- Linear vector-bracket syzygy in the source-oriented presentation. -/
def sourceOrientedLinearSyzygyRelation
    (d n : ℕ)
    (i : Fin n)
    (ι : Fin (d + 2) ↪ Fin n) :
    sourceOrientedInvariantCoordinateRing d n :=
  ∑ k : Fin (d + 2),
    MvPolynomial.C ((-1 : ℂ) ^ (k : ℕ)) *
      MvPolynomial.X (Sum.inl (i, ι k)) *
        MvPolynomial.X (Sum.inr (finDeleteEmbedding k ι))

/-- Explicit source-side oriented relation generators.  Compared with the
standard-dot presentation, the Cauchy-Binet relation carries the fixed
Minkowski metric determinant factor. -/
def sourceOrientedAlgebraicRelationGenerators
    (d n : ℕ) :
    Set (sourceOrientedInvariantCoordinateRing d n) :=
  ((Set.range
      (fun ij : Fin n × Fin n =>
        MvPolynomial.X (Sum.inl ij) -
          MvPolynomial.X (Sum.inl (ij.2, ij.1)))) ∪
    (Set.range
      (fun ι : Fin (d + 2) ↪ Fin n =>
        Matrix.det
          (fun a b : Fin (d + 2) =>
            MvPolynomial.X (Sum.inl (ι a, ι b))))) ∪
    (Set.range
      (fun p : (Fin (d + 1) ↪ Fin n) × Equiv.Perm (Fin (d + 1)) =>
        MvPolynomial.X (Sum.inr (p.2.toEmbedding.trans p.1)) -
          MvPolynomial.C (p.2.sign : ℂ) *
            (MvPolynomial.X (Sum.inr p.1) :
              sourceOrientedInvariantCoordinateRing d n))) ∪
    (Set.range
      (fun p : (Fin (d + 1) ↪ Fin n) × (Fin (d + 1) ↪ Fin n) =>
        Matrix.det
            (fun a b : Fin (d + 1) =>
              MvPolynomial.X (Sum.inl (p.1 a, p.2 b))) -
          MvPolynomial.C (BHW.minkowskiMetricDet d) *
            (MvPolynomial.X (Sum.inr p.1) :
              sourceOrientedInvariantCoordinateRing d n) *
              (MvPolynomial.X (Sum.inr p.2) :
                sourceOrientedInvariantCoordinateRing d n)))) ∪
  (Set.range
    (fun p : Fin n × (Fin (d + 2) ↪ Fin n) =>
      sourceOrientedLinearSyzygyRelation d n p.1 p.2))

/-- The ideal generated by the explicit source-oriented relations. -/
def sourceOrientedAlgebraicRelationIdeal
    (d n : ℕ) :
    Ideal (sourceOrientedInvariantCoordinateRing d n) :=
  Ideal.span (sourceOrientedAlgebraicRelationGenerators d n)

end BHW
